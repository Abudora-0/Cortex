# --- Database ---
# Local dev uses SQLite (zero config). For production, switch the datasource
# provider in prisma/schema.prisma to "postgresql", swap the driver adapter in
# src/lib/db.ts, and point this at your Neon/Postgres instance.
DATABASE_URL="file:./prisma/dev.db"

# --- Auth.js ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-me"

# Google OAuth (https://console.cloud.google.com > APIs & Services > Credentials)
# Redirect URI: http://localhost:3001/api/auth/callback/google
# Leave empty to use the dev-only email login instead.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Set to "true" to allow passwordless dev login (auto-enabled in development)
AUTH_DEV_LOGIN=""

# --- LMS credential vault ---
# 32-byte hex key for AES-256-GCM encryption of stored LMS passwords.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_KEY="replace-me"

# --- UET LMS ---
LMS_BASE_URL="https://lms.uet.edu.pk"
