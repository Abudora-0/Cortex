    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.56.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5",
