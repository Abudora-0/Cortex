{
  "name": "cortex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm install --no-audit --no-fund && node scripts/prepare-db.mjs && npx prisma generate && npx prisma db push",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "tsx worker/index.ts",
    "lms:connect": "tsx worker/connect.ts",
    "lms:explore": "tsx worker/explore.ts",
    "lms:rpc": "tsx worker/rpc.ts",
    "lms:obe": "tsx worker/obe.ts",
    "lms:menus": "tsx worker/menus.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/pm": "^3.7.0",
    "@tiptap/react": "^3.7.0",
    "@tiptap/starter-kit": "^3.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "googleapis": "^161.0.0",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
